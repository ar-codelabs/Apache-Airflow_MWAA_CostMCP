{
  "mcpServers": {
    "cmdb-server": {
      "command": "python",
      "args": ["mcp_server.py"],
      "env": {
        "AWS_DEFAULT_REGION": "us-east-1"
      },
      "skill": "cmdb",
      "label": "📊 CMDB (S3)",
      "internal": true
    },
    "billing": {
      "command": "uvx",
